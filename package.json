    "uuid": "^9.0.1",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "nodemon": "^3.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ssh2": "^1.17.0",
    "vite": "^8.0.3"
  },
