{
  "name": "leadgen-scraper",
  "version": "2.0.0",
  "description": "Production-grade high-throughput web scraping system",
  "main": "api/server.js",
  "scripts": {
    "start:api": "node api/server.js",
    "start:worker": "node workers/worker.js",
    "dev:api": "nodemon api/server.js",
