# ═══════════════════════════════════════════════════════════
#  LeadGen Scraper — Environment Configuration
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Server ───────────────────────────────────────────────
PORT=3000
RATE_LIMIT=200            # requests per minute per IP
API_TIMEOUT=90000         # ms to wait for synchronous /search result

# ── Scraper ──────────────────────────────────────────────────
HEADLESS=true             # set to false to watch browser (debug)
SCRAPE_TIMEOUT=30000      # ms per page navigation
NAV_TIMEOUT=25000
BLOCK_RESOURCES=true      # block images/css for speed

# ── Worker ───────────────────────────────────────────────────
WORKER_CONCURRENCY=20     # simultaneous jobs per worker process
                          # Scale to 50 with good proxies
STALL_INTERVAL=30000

# ── Queue ─────────────────────────────────────────────────────
MAX_RETRIES=3
BACKOFF_DELAY=2000        # base ms for exponential backoff
JOB_TIMEOUT=120000

# ── CAPTCHA (optional) ────────────────────────────────────────
CAPTCHA_API_KEY=          # 2Captcha or Anti-Captcha key
CAPTCHA_SERVICE=2captcha  # '2captcha' | 'anti-captcha'

# ── Proxies (optional but highly recommended) ─────────────────
# Comma-separated list. Formats:
#   http://user:pass@host:port
#   host:port:user:pass
#   host:port:user:pass:us-east   (with region tag)
#
# Free proxy lists (low reliability, high noise):
#   https://free-proxy-list.net
#   https://proxylist.geonode.com
#
# Paid residential (recommended for scale):
#   BrightData, Oxylabs, Smartproxy, IPRoyal
#
PROXIES=

# ── Paid API fallbacks (optional — used when free scraping fails) ─
SCRAPINGDOG_API_KEY=      # https://scrapingdog.com  ($0.00033/req)
SERPAPI_KEY=              # https://serpapi.com      ($0.00916/req)
SCRAPINGBEE_KEY=          # https://scrapingbee.com

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info            # debug | info | warn | error
LOG_DIR=./logs
